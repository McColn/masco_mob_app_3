# MASCO Mobile — Environment Configuration
# ==========================================
# Copy this file to .env (same folder as package.json)
# Then run: npx expo start --clear
#
# From the Django URL conf:
#   Web app  →  https://365microfinance.mccoln.com/masco/...
#   API      →  https://365microfinance.mccoln.com/api/...
#
# So the correct base URL is:
EXPO_PUBLIC_API_URL=https://365microfinance.mccoln.com/api

# Local development (phone on same WiFi as your PC)
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8000/api
